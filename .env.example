# 배포(Render) 환경변수 템플릿 — 실제 값은 Render 대시보드의 Environment 에 입력하세요.
# (이 파일은 커밋해도 안전합니다. 진짜 키는 절대 여기 적지 마세요.)

PUBLIC_DATA_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
EMAIL_ADDRESS=
EMAIL_PASSWORD=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2-chat-latest

# 회의실 비밀번호 (공개 배포 시 반드시 설정 → OpenAI 비용 보호)
CONFERENCE_PASSWORD=
# 세션 암호화 키 (길고 무작위한 문자열로 설정)
SECRET_KEY=

# ── 구독: 저장 DB (Neon/Supabase Postgres 연결 문자열) ──
# 예: postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=

# ── 구독: 이메일 발송 (Brevo 권장, 도메인 없어도 단일발신자 인증으로 가능) ──
# Brevo: SMTP_HOST=smtp-relay.brevo.com / PORT=587 / USER=브레보로그인 / PASS=SMTP키
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# 발신자 주소(브레보에서 인증한 이메일)
MAIL_FROM=

# 수신거부 링크에 쓸 배포 URL (예: https://your-app.onrender.com)
APP_BASE_URL=
# 매일 자동발송 엔드포인트 보호 토큰 (cron-job.org 가 이 토큰으로 호출)
CRON_TOKEN=
